<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hydroponic Water Quality Dashboard</title>
    <!-- Tailwind CSS untuk Styling Modern -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Paho MQTT Library via CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/paho-mqtt/1.0.1/mqttws31.min.js" type="text/javascript"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen font-sans">

    <!-- Header -->
    <header class="bg-slate-800 border-b border-slate-700 py-6 px-8 shadow-md">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
            <div>
                <h1 class="text-2xl font-bold text-emerald-400">Hidroponik IoT Dashboard</h1>
                <p class="text-sm text-slate-400">Pemantauan Kualitas Air Real-time</p>
            </div>
            <div class="flex items-center gap-3 bg-slate-900 px-4 py-2 rounded-full border border-slate-700">
                <div id="status-indicator" class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
                <span id="status-text" class="text-sm font-medium text-slate-300">Terputus</span>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
        
        <!-- Grid Sensor Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            
            <!-- Card Suhu -->
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-sm hover:border-emerald-500/50 transition">
                <div class="text-sm font-medium text-slate-400 mb-1">Suhu Air</div>
                <div class="flex items-baseline gap-1">
                    <span id="val-temp" class="text-4xl font-extrabold text-white">--</span>
                    <span class="text-lg font-medium text-slate-400">°C</span>
                </div>
            </div>

            <!-- Card Kelembaban -->
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-sm hover:border-emerald-500/50 transition">
                <div class="text-sm font-medium text-slate-400 mb-1">Kelembaban Udara</div>
                <div class="flex items-baseline gap-1">
                    <span id="val-hum" class="text-4xl font-extrabold text-white">--</span>
                    <span class="text-lg font-medium text-slate-400">%</span>
                </div>
            </div>

            <!-- Card pH -->
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-sm hover:border-emerald-500/50 transition">
                <div class="text-sm font-medium text-slate-400 mb-1">Tingkat pH</div>
                <div class="flex items-baseline gap-1">
                    <span id="val-ph" class="text-4xl font-extrabold text-white">--</span>
                </div>
            </div>

            <!-- Card Kekeruhan -->
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-sm hover:border-emerald-500/50 transition">
                <div class="text-sm font-medium text-slate-400 mb-1">Kekeruhan Air</div>
                <div class="flex items-baseline gap-1">
                    <span id="val-turbidity" class="text-4xl font-extrabold text-white">--</span>
                    <span class="text-lg font-medium text-slate-400">NTU</span>
                </div>
            </div>

        </div>

        <!-- Log Data Terakhir -->
        <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-sm">
            <h3 class="text-md font-semibold text-slate-300 mb-4">Payload JSON Terakhir Diterima:</h3>
            <div class="bg-slate-900 rounded-xl p-4 font-mono text-sm text-emerald-400 overflow-x-auto border border-slate-750">
                <span id="raw-payload">// Menunggu data dari ESP32...</span>
            </div>
            <div class="text-xs text-slate-500 mt-2 text-right">
                Terakhir Diperbarui: <span id="last-update">-</span>
            </div>
        </div>

    </main>

    <!-- MQTT Logic Configuration -->
    <script>
        // Konfigurasi koneksi broker HiveMQ via WebSockets Secure
        const MQTT_HOST = "broker.hivemq.com";
        const MQTT_PORT = 8884; // Port WSS untuk koneksi HTTPS aman
        const MQTT_TOPIC = "hidroponik/kualitas_air";
        const CLIENT_ID = "web_dashboard_" + Math.random().toString(16).substr(2, 8);

        // Inisialisasi Paho MQTT Client
        const client = new Paho.MQTT.Client(MQTT_HOST, Number(MQTT_PORT), CLIENT_ID);

        // Callback Event Handlers
        client.onConnectionLost = onConnectionLost;
        client.onMessageArrived = onMessageArrived;

        // Opsi Koneksi (Gunakan SSL/TLS karena berjalan di GitHub Pages)
        const connectOptions = {
            onSuccess: onConnect,
            onFailure: onFailure,
            useSSL: true,
            timeout: 3,
            keepAliveInterval: 60
        };

        // Mulai koneksi ke broker
        console.log("Menghubungkan ke broker MQTT...");
        client.connect(connectOptions);

        function onConnect() {
            console.log("Terhubung ke MQTT Broker!");
            document.getElementById("status-indicator").className = "w-3 h-3 rounded-full bg-emerald-500";
            document.getElementById("status-text").innerText = "Terhubung";
            document.getElementById("status-text").className = "text-sm font-medium text-emerald-400";
            
            // Subscribe ke topik yang sama dengan ESP32
            client.subscribe(MQTT_TOPIC);
        }

        function onFailure(message) {
            console.log("Koneksi gagal: " + message.errorMessage);
            setTimeout(() => client.connect(connectOptions), 5000); // Coba lagi dalam 5 detik
        }

        function onConnectionLost(responseObject) {
            if (responseObject.errorCode !== 0) {
                console.log("Koneksi terputus: " + responseObject.errorMessage);
                document.getElementById("status-indicator").className = "w-3 h-3 rounded-full bg-red-500 animate-pulse";
                document.getElementById("status-text").innerText = "Terputus";
                document.getElementById("status-text").className = "text-sm font-medium text-slate-300";
                
                // Coba hubungkan kembali secara otomatis
                setTimeout(() => client.connect(connectOptions), 5000);
            }
        }

        function onMessageArrived(message) {
            console.log("Data masuk: " + message.payloadString);
            
            try {
                // Parsing data JSON yang dikirim oleh ESP32
                const data = JSON.parse(message.payloadString);
                
                // Update elemen UI
                if (data.temperature !== undefined) document.getElementById("val-temp").innerText = Number(data.temperature).toFixed(2);
                if (data.humidity !== undefined) document.getElementById("val-hum").innerText = Number(data.humidity).toFixed(1);
                if (data.pH !== undefined) document.getElementById("val-ph").innerText = Number(data.pH).toFixed(2);
                if (data.turbidity !== undefined) document.getElementById("val-turbidity").innerText = Number(data.turbidity).toFixed(2);
                
                // Tampilkan payload mentah dan penanda waktu
                document.getElementById("raw-payload").innerText = message.payloadString;
                document.getElementById("last-update").innerText = new Date().toLocaleTimeString();
                
            } catch (error) {
                console.error("Format data bukan JSON valid:", error);
            }
        }
    </script>
</body>
</html>
